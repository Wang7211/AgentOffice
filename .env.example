APP_NAME=AI Enterprise Agent
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
DATABASE_URL=mysql+pymysql://agentoffice:agentoffice123@127.0.0.1:3306/agentoffice?charset=utf8mb4
REDIS_URL=redis://localhost:6379/0
MODEL_PROVIDER=qwen
MODEL_NAME=qwen3.5-122b-a10b

# OpenAI 模型接入配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek 模型接入配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 OpenAI 兼容模式接入配置
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-122b-a10b

TAVILY_API_KEY=
UPLOAD_DIR=./data/uploads
VECTOR_STORE_DIR=./data/vector_store
MAX_UPLOAD_MB=20
CHAT_WINDOW_SIZE=10
REQUEST_TIMEOUT=60
KNOWLEDGE_SIMILARITY_THRESHOLD=0.12
AGENT_MEMORY_SIMILARITY_THRESHOLD=0.08
MCP_HTTP_ENDPOINT=
MCP_API_KEY=

# JWT 认证密钥（生产环境请更换为复杂密钥）
JWT_SECRET_KEY=agentoffice-secret-key-change-in-production
